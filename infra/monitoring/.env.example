# Copy to .env (gitignored) and fill in real values before running
# `docker compose up` from this directory.

# Grafana admin login (default admin/admin)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Slack incoming webhook URL for the #alerts channel
SLACK_WEBHOOK_URL=

# PagerDuty integration key (Events API v1) for critical alerts
PAGERDUTY_SERVICE_KEY=

# Kibana (log search UI)
KIBANA_PORT=5601
KIBANA_VERSION=8.13.4

# Filebeat (log shipper)
FILEBEAT_VERSION=8.13.4

# Elasticsearch credentials forwarded to Filebeat (leave blank for unauthenticated local dev)
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
