# Terraform Backend Configuration Example
# Copy this file to backend.tf and update with your values
# This configuration enables remote state storage with S3 and DynamoDB for state locking

terraform {
  backend "s3" {
    # S3 bucket for storing Terraform state files
    bucket = "teachlink-terraform-state"

    # Path to the state file within the bucket
    key    = "terraform/teachlink-dev/terraform.tfstate"

    # AWS region where the S3 bucket is located
    region = "us-east-1"

    # DynamoDB table for state locking and consistency
    dynamodb_table = "teachlink-terraform-state-lock"

    # Enable server-side encryption for the state file
    encrypt = true

    # Enable versioning for the state file
    # This allows you to recover previous versions of your state
    # (requires versioning enabled on the S3 bucket)
    # versioning = true
  }
}

# Note: Before using this configuration, you must:
# 1. Create the S3 bucket:
#    aws s3api create-bucket --bucket teachlink-terraform-state --region us-east-1
#    aws s3api put-bucket-versioning --bucket teachlink-terraform-state --versioning-configuration Status=Enabled
#
# 2. Create the DynamoDB table:
#    aws dynamodb create-table \
#      --table-name teachlink-terraform-state-lock \
#      --attribute-definitions AttributeName=LockID,AttributeType=S \
#      --key-schema AttributeName=LockID,KeyType=HASH \
#      --billing-mode PAY_PER_REQUEST
#
# 3. Update the bucket name, key, and region to match your setup
#
# 4. For production environments, consider using separate state files per environment:
#    key = "terraform/teachlink-prod/terraform.tfstate"
